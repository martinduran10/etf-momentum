# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Testing / coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- Project-specific ---
# Local scratch / experiments (anything under scratch/ is local-only)
scratch/

# Generated reports and large outputs (keep the folder via .gitkeep)
reports/*.pdf
reports/*.png
reports/*.html
!reports/.gitkeep

# Sensitive config (e.g., Bloomberg API credentials, if you add them later)
.env
config/secrets.yaml

# Logs
*.log
logs/

# Original source workbooks (the raw .xlsx file is too large for git)
*.xlsx
*.xlsm
